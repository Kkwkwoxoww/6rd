javascript:(function(){var apiKey='8KfFsYlCDSRuLnurfyBjJjil7stjm38RZsRUszpG';var clusterId='free.blr2';var roomId='62u85L';if(document.getElementById('gartic-multi-ui')){alert('الواجهة تعمل بالفعل!');return;}var wsUrl='wss://'+clusterId+'.piesocket.com/v3/'+roomId+'?api_key='+apiKey;var socket=new WebSocket(wsUrl);socket.onmessage=function(event){var data=JSON.parse(event.data);if(data.action==='kick'){console.log('وصل أمر طرد للاعب رقم: '+data.index);executeKick(data.index);}};var container=document.createElement('div');container.id='gartic-multi-ui';container.style='fixed;top:10px;right:10px;width:240px;background:rgba(0,0,0,0.9);color:#fff;padding:10px;border-radius:8px;z-index:999999;direction:rtl;position:fixed;box-shadow:0 4px 15px rgba(0,0,0,0.5);border:1px solid #444;font-family:Arial,sans-serif;';document.body.appendChild(container);var title=document.createElement('div');title.textContent='🌐 طرد جماعي (ثلاث صفحات)';title.style.fontWeight='bold';title.style.marginBottom='8px';title.style.textAlign='center';container.appendChild(title);var playersList=document.createElement('div');playersList.style='max-height:100px;overflow-y:auto;background:#222;margin:5px 0;padding:5px;border-radius:4px;';playersList.textContent='اضغط تحديث لرؤية اللاعبين...';container.appendChild(playersList);var findBtn=document.createElement('button');findBtn.textContent='🔄 تحديث القائمة';findBtn.style='width:100%;background:#28a745;color:#fff;border:none;padding:5px;margin-bottom:5px;border-radius:4px;font-weight:bold;';container.appendChild(findBtn);var kickInput=document.createElement('input');kickInput.type='number';kickInput.placeholder='رقم اللاعب...';kickInput.style='width:60%;padding:4px;border-radius:4px;border:none;';container.appendChild(kickInput);var kickBtn=document.createElement('button');kickBtn.textContent='❌ طرد للكل';kickBtn.style='width:35%;background:#dc3545;color:#fff;border:none;padding:5px;margin-right:5%;border-radius:4px;font-weight:bold;';container.appendChild(kickBtn);findBtn.onclick=function(){var nicks=document.querySelectorAll('.nick');playersList.innerHTML='';nicks.forEach(function(el,index){playersList.innerHTML+='<div style="border-bottom:1px solid #333;padding:2px 0;">'+(index+1)+' - '+el.textContent.trim()+'</div>';});};kickBtn.onclick=function(){var choice=kickInput.value.trim();if(!choice)return;var playerIndex=parseInt(choice)-1;var message=JSON.stringify({action:'kick',index:playerIndex});socket.send(message);kickInput.value='';};function executeKick(playerIndex){var nicks=document.querySelectorAll('.nick');if(playerIndex<0||playerIndex>=nicks.length)return;var target=nicks[playerIndex].closest('.user,[class*="user"]');if(target){target.click();setTimeout(function(){var allButtons=document.querySelectorAll('button,div,span,a');allButtons.forEach(function(btn){var txt=btn.textContent?btn.textContent.trim().toUpperCase():'';if(txt.includes('VOTEKICK')||txt.includes('KICK')){btn.click();}});},600);}}}    )();
